# 真实 API 模式配置
# VITE_API_BASE_URL 默认空 = 同源（前端走相对路径，与后端同 origin）。
#   - 内网 / Spring Boot 一体部署：保持空（同源），或用 npm run build:samesite
#   - 公网 / 域名部署：用 PRODUCTION_API_BASE_URL=https://<域名> ./scripts/release/package-release.sh
#   - 本地 dev：dev-frontend.sh / dev-services.sh 自动注入 http://127.0.0.1:${BACKEND_PORT}，不读本值
# 历史教训：默认 localhost:18086 会让裸 `npm run build:api` 产出 dev baseURL 的前端，
# 误部署到服务器即全 API 调错后端（IP:8080 跨域 403 的成因之一）。
VITE_API_MODE=api
VITE_API_BASE_URL=
VITE_ENABLE_MOCK_LOGIN=false

# Sentry 前端错误追踪配置
# DSN 从 Sentry 项目设置获取，不配置则 Sentry 自动禁用
# 生产环境通过 CI/CD 或部署脚本注入真实 DSN
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=dev
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
